# Sanity CMS Configuration
# Get these values from your Sanity project at https://www.sanity.io/manage

# Your Sanity Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Your Sanity Dataset (usually 'production')
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API Version (format: YYYY-MM-DD)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: Sanity API Token for authenticated requests
# Create this in Sanity Studio > Settings > API > Tokens
# SANITY_API_TOKEN=your_token_here

# Next.js Configuration
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
